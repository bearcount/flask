+class TestCSRFProtect:
+    """Test suite for CSRFProtect class."""
+
+    def test_init_without_app(self):
+        """Test CSRFProtect can be initialized without app."""
+        csrf = CSRFProtect()
+        assert csrf._app is None
+        assert csrf.cookie_name == "csrf_token"
+        assert csrf.header_name == "X-CSRF-Token"
+        assert csrf.field_name == "csrf_token"
+
+    def test_init_with_app(self, app: Flask):
+        """Test CSRFProtect initialized with app."""
+        csrf = CSRFProtect(app)
+        assert csrf._app is app
+        assert app.config["CSRF_ENABLED"] is True
+        assert app.config["CSRF_COOKIE_NAME"] == "csrf_token"
+
+    def test_init_app(self, app: Flask):
+        """Test init_app method."""
+        csrf = CSRFProtect()
+        csrf.init_app(app)
+        assert csrf._app is app
+
+    def test_custom_config(self, app: Flask):
+        """Test custom configuration options."""
+        csrf = CSRFProtect(
+            app,
+            cookie_name="custom_csrf",
+            header_name="X-Custom-CSRF",
+            cookie_secure=False,
+            cookie_samesite="Strict",
+        )
+        assert csrf.cookie_name == "custom_csrf"
+        assert csrf.header_name == "X-Custom-CSRF"
+        assert csrf.cookie_secure is False
+        assert csrf.cookie_samesite == "Strict"
