 from .signals import before_render_template
 from .signals import template_rendered

@@ -140,6 +141,13 @@ def _default_template_ctx_processor() -> dict[str, t.Any]:
     ctx = app_ctx._get_current_object()
     rv: dict[str, t.Any] = {"g": ctx.g}

+    # Add CSRF token helpers if CSRF is enabled
+    if hasattr(ctx.app, 'csrf') and ctx.app.csrf is not None:
+        rv["csrf_token_value"] = generate_csrf
+        rv["csrf_token"] = csrf_token
+        rv["csrf_input"] = csrf_input
+
     if ctx.has_request:
         rv["request"] = ctx.request
         # The session proxy cannot be replaced, accessing it gets
--
